#!/usr/bin/env bash
#
# convertimg — Convert all images in the current folder to a target format using ImageMagick.
#
# Usage:  convertimg [options] <format>
#
# Arguments:
#   <format>          Target format extension (e.g. jpg, png, webp, avif, tiff)
#
# Options:
#   -q, --quality N   Compression quality 1–100 (default: 85; only for lossy formats)
#   -k, --keep        Keep original files (default: trash them after successful conversion)
#   -n, --dry-run     Show what would be converted without doing anything
#       --help        Show this help message
#
# Examples:
#   convertimg webp
#   convertimg --quality 90 jpg
#   convertimg --keep png
#   convertimg --dry-run avif
#

set -euo pipefail

# ── Colors & Logging ─────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${CYAN}[INFO]${NC} $*"; }
log_ok()   { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
log_err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }

die()     { log_err "$*"; exit 1; }
require() { command -v "$1" &>/dev/null || die "'$1' is not installed or not in PATH"; }

usage() {
  sed -n '3,22p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# ── Trash helper ─────────────────────────────────────────────────────────────
trash_file() {
  local f="$1"
  if command -v gio &>/dev/null; then
    gio trash "$f"
  elif command -v trash-put &>/dev/null; then
    trash-put "$f"
  elif command -v osascript &>/dev/null; then
    osascript -e "tell app \"Finder\" to delete POSIX file \"$(realpath "$f")\"" &>/dev/null
  elif command -v powershell.exe &>/dev/null; then
    local win_path
    win_path=$(cygpath -w "$f" 2>/dev/null || echo "$f")
    powershell.exe -NoProfile -Command "
      Add-Type -AssemblyName Microsoft.VisualBasic
      [Microsoft.VisualBasic.FileIO.FileSystem]::DeleteFile(
        '${win_path//\'/\'\'}',
        'OnlyErrorDialogs',
        'SendToRecycleBin'
      )
    " 2>/dev/null && return
    rm -f "$f"
  else
    rm -f "$f"
  fi
}

# ── Defaults ─────────────────────────────────────────────────────────────────
QUALITY=85
KEEP=false
DRY_RUN=false

# ── Argument parsing ──────────────────────────────────────────────────────────
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -q|--quality)  [[ $# -ge 2 ]] || die "--quality requires an argument"; QUALITY="$2"; shift 2 ;;
    -k|--keep)     KEEP=true; shift ;;
    -n|--dry-run)  DRY_RUN=true; shift ;;
    --help)        usage 0 ;;
    -*)            die "unknown option: $1" ;;
    *)             POSITIONAL+=("$1"); shift ;;
  esac
done

[[ ${#POSITIONAL[@]} -ge 1 ]] || { log_err "target format is required"; usage 1; }
TARGET_FMT="${POSITIONAL[0]}"
# Normalise: strip leading dot if user typed e.g. ".webp"
TARGET_FMT="${TARGET_FMT#.}"

# Validate quality range
[[ "$QUALITY" =~ ^[0-9]+$ ]] && [[ "$QUALITY" -ge 1 && "$QUALITY" -le 100 ]] \
  || die "--quality must be a number between 1 and 100"

# ── Prerequisite check ────────────────────────────────────────────────────────
require magick

# ── Collect source images ─────────────────────────────────────────────────────
IMAGE_EXTS="jpg jpeg png gif bmp tiff tif webp avif heic heif ico svg"
mapfile -t IMAGES < <(
  for ext in $IMAGE_EXTS; do
    # Match both lower and upper case extensions
    compgen -G "*.$ext"    2>/dev/null || true
    compgen -G "*.${ext^^}" 2>/dev/null || true
  done | sort -u
)

if [[ ${#IMAGES[@]} -eq 0 ]]; then
  log_warn "No images found in the current directory."
  exit 0
fi

# ── Filter out files already in the target format ────────────────────────────
TO_CONVERT=()
for img in "${IMAGES[@]}"; do
  ext_lower="${img##*.}"
  ext_lower="${ext_lower,,}"
  if [[ "$ext_lower" == "${TARGET_FMT,,}" ]]; then
    log_info "Skipping (already $TARGET_FMT): $img"
    continue
  fi
  TO_CONVERT+=("$img")
done

if [[ ${#TO_CONVERT[@]} -eq 0 ]]; then
  log_warn "All images are already in $TARGET_FMT format."
  exit 0
fi

log_info "Found ${#TO_CONVERT[@]} image(s) to convert → .$TARGET_FMT (quality: $QUALITY)"
$DRY_RUN && log_warn "Dry-run mode — no files will be changed."
echo ""

# ── Convert ───────────────────────────────────────────────────────────────────
CONVERTED=0
FAILED=0

for src in "${TO_CONVERT[@]}"; do
  stem="${src%.*}"
  dest="${stem}.${TARGET_FMT}"

  if $DRY_RUN; then
    log_info "[dry-run] $src  →  $dest"
    continue
  fi

  # Avoid overwriting an existing file with a different source
  if [[ -e "$dest" && "$dest" != "$src" ]]; then
    log_warn "Skipping '$src': destination '$dest' already exists"
    continue
  fi

  if magick "$src" -quality "$QUALITY" "$dest" 2>/dev/null; then
    log_ok "$src  →  $dest"
    (( CONVERTED++ )) || true
    if ! $KEEP && [[ "$dest" != "$src" ]]; then
      trash_file "$src"
    fi
  else
    log_err "Failed to convert: $src"
    (( FAILED++ )) || true
    [[ -e "$dest" ]] && rm -f "$dest"
  fi
done

$DRY_RUN && exit 0

echo ""
log_ok "Done. Converted: $CONVERTED  |  Failed: $FAILED"
