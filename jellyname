#!/usr/bin/env bash
#
# jellyname — Rename and organize media files for Jellyfin compatibility.
#
# Usage:  jellyname [options] [directory]
#
# Scans [directory] (top level only) for video files, parses each filename to
# extract title, year, season/episode, and resolution, then renames and moves
# each file into a Jellyfin-compatible folder structure inside <directory>.
#
# Output structure:
#   Movies:   Movie Name (Year)/Movie Name (Year) - 1080p.mkv
#   TV/Anime: Show Name/Season 01/Show Name S01E01 - 720p.mkv
#
# Resolution is preserved as a Jellyfin version-label suffix ( - 1080p).
# Junk tags (BluRay, x264, HEVC, WEB-DL, etc.) are stripped from filenames.
# Characters illegal in Jellyfin paths (< > : " / \ | ? *) are removed.
#
# If no directory is given, the current working directory is used.
#
# Options:
#   -n, --dry-run     Preview what would be renamed without moving any files
#       --help        Show this help message
#
# Examples:
#   jellyname
#   jellyname ~/Downloads/movies
#   jellyname --dry-run /mnt/media/shows
#

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${CYAN}[INFO]${NC} $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# ── Helpers ───────────────────────────────────────────────────────────────────
usage() {
  sed -n '3,27p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

die() { log_err "$*"; exit 1; }

# Normalize dots and underscores used as word separators → spaces, trim edges.
# Leaves dots inside known patterns (e.g. H.265) alone — those get stripped
# later by strip_junk anyway.
normalize_name() {
  local name="$1"
  # Replace dots/underscores between word chars with a space
  name=$(echo "$name" | sed 's/[._]/ /g')
  # Collapse multiple spaces, trim leading/trailing
  name=$(echo "$name" | tr -s ' ' | sed 's/^ //;s/ $//')
  echo "$name"
}

# Strip common quality/codec/source/audio tags from a (already normalized) string.
# These words are removed case-insensitively, including any surrounding spaces.
strip_junk() {
  local name="$1"
  local junk_re
  # Order matters: longer / more specific patterns first
  junk_re='[[:space:]]*(2160p|1080[pi]|720[pi]|480[pi]|4[Kk]|'
  junk_re+='BluRay|Blu-Ray|Blu Ray|BDRip|BRRip|'
  junk_re+='WEB-DL|WEBRip|WEB DL|WEB|HDRip|DVDRip|HDTV|AMZN|HULU|DSNP|'
  junk_re+='x264|x265|H 264|H 265|HEVC|AVC|XviD|DivX|'
  junk_re+='AAC|AC3|DTS|FLAC|TrueHD|Atmos|DDP5 1|DD5 1|EAC3|'
  junk_re+='HDR10\+|HDR10|Dolby Vision|HDR|DV|SDR|'
  junk_re+='REMUX|PROPER|REPACK|EXTENDED|THEATRICAL|REMASTERED|IMAX|'
  junk_re+='10bit|10 bit|8bit|8 bit|Hi10P)[[:space:]]*'
  # Run sed in a loop until no more matches (handles multiple consecutive tags)
  local prev=""
  while [[ "$name" != "$prev" ]]; do
    prev="$name"
    name=$(echo "$name" | perl -pe "s/${junk_re}/ /gi" | tr -s ' ' | sed 's/^ //;s/ $//')
  done
  echo "$name"
}

# Extract a resolution string from the raw (un-normalized) filename stem.
# Outputs the canonical label (e.g. "1080p", "2160p") or empty string.
extract_resolution() {
  local raw="$1"
  local res=""
  # 4K / 4k → 2160p (surrounded by non-alphanumeric, or at boundary)
  if echo "$raw" | grep -iqE '(^|[^0-9a-zA-Z])4[Kk]($|[^0-9a-zA-Z])'; then
    res="2160p"
  else
    res=$(echo "$raw" \
      | grep -ioE '(^|[^a-zA-Z])(2160[pi]|1080[pi]|720[pi]|480[pi])($|[^a-zA-Z])' \
      | grep -ioE '2160[pi]|1080[pi]|720[pi]|480[pi]' \
      | head -1 | tr '[:upper:]' '[:lower:]' || true)
  fi
  echo "$res"
}

# Remove characters that are illegal in Jellyfin paths: < > : " / \ | ? *
# Also remove leading/trailing dots and spaces (Windows reserved).
sanitize_for_path() {
  local name="$1"
  # Strip illegal chars
  name=$(echo "$name" | sed 's/[<>:"/\\|?*]//g')
  # Strip leading/trailing dots and spaces
  name=$(echo "$name" | sed 's/^[. ]*//;s/[. ]*$//')
  echo "$name"
}

# Parse a TV/anime filename.
# Sets globals: SHOW_NAME, SEASON_NUM, EPISODE_NUM (zero-padded strings)
# Returns 1 if no episode pattern found.
parse_tv() {
  local stem="$1"
  local norm
  norm=$(normalize_name "$stem")

  # Match S##E## or ##x## (case-insensitive)
  local ep_match
  ep_match=$(echo "$norm" | grep -ioE '[Ss]([0-9]{1,2})[Ee]([0-9]{1,2})|([0-9]{1,2})x([0-9]{1,2})' | head -1 || true)
  [[ -z "$ep_match" ]] && return 1

  # Extract season and episode numbers
  if echo "$ep_match" | grep -qiE '^[Ss][0-9]'; then
    # S01E02 format
    SEASON_NUM=$(echo "$ep_match" | grep -ioE '[Ss]([0-9]{1,2})' | grep -oE '[0-9]+' | head -1)
    EPISODE_NUM=$(echo "$ep_match" | grep -ioE '[Ee]([0-9]{1,2})' | grep -oE '[0-9]+' | head -1)
  else
    # 1x02 format
    SEASON_NUM=$(echo "$ep_match" | cut -dx -f1)
    EPISODE_NUM=$(echo "$ep_match" | cut -dx -f2)
  fi

  # Zero-pad to 2 digits
  SEASON_NUM=$(printf '%02d' "${SEASON_NUM#0}")
  EPISODE_NUM=$(printf '%02d' "${EPISODE_NUM#0}")

  # Show name = everything before the episode marker, stripped and cleaned
  local before_ep
  # Use sed to extract the part before the episode tag (avoids lookahead)
  before_ep=$(echo "$norm" | sed -E 's/[[:space:]]*[Ss][0-9]{1,2}[Ee][0-9]{1,2}.*//')
  if [[ "$before_ep" == "$norm" ]]; then
    # Didn't match SxxExx; try ##x## format
    before_ep=$(echo "$norm" | sed -E 's/[[:space:]]*[0-9]{1,2}[xX][0-9]{1,2}.*//')
  fi
  before_ep=$(strip_junk "$before_ep")
  before_ep=$(sanitize_for_path "$before_ep")
  # Remove trailing dash/space artifacts
  before_ep=$(echo "$before_ep" | sed 's/[[:space:]]*-[[:space:]]*$//;s/[[:space:]]*$//')
  SHOW_NAME="$before_ep"

  # Episode title = everything after the episode marker, junk stripped.
  # Truncate at the first resolution/quality tag — everything from that point
  # on (codec, source, release group, etc.) is unnecessary.
  local after_ep
  after_ep=$(echo "$norm" | sed -E 's/.*[Ss][0-9]{1,2}[Ee][0-9]{1,2}[[:space:]]*//')
  if [[ "$after_ep" == "$norm" ]]; then
    # Didn't match SxxExx; try ##x## format
    after_ep=$(echo "$norm" | sed -E 's/.*[0-9]{1,2}[xX][0-9]{1,2}[[:space:]]*//')
  fi
  # Drop everything from the first resolution tag onwards
  after_ep=$(echo "$after_ep" | sed -E 's/[[:space:]]*(2160[pi]|1080[pi]|720[pi]|480[pi]|4[Kk])[[:space:]].*//' \
    | sed -E 's/[[:space:]]*(2160[pi]|1080[pi]|720[pi]|480[pi]|4[Kk])$//')
  after_ep=$(strip_junk "$after_ep")
  after_ep=$(sanitize_for_path "$after_ep")
  after_ep=$(echo "$after_ep" | sed 's/^[[:space:]]*-[[:space:]]*//;s/[[:space:]]*-[[:space:]]*$//;s/[[:space:]]*$//')
  EPISODE_TITLE="$after_ep"
  return 0
}

# Parse a movie filename.
# Sets globals: MOVIE_TITLE, MOVIE_YEAR (may be empty)
parse_movie() {
  local stem="$1"
  local norm
  norm=$(normalize_name "$stem")

  # Find first 4-digit year (1900–2099)
  local year
  year=$(echo "$norm" | grep -oE '\b(19[0-9]{2}|20[0-9]{2})\b' | head -1 || true)
  MOVIE_YEAR="$year"

  local title
  if [[ -n "$year" ]]; then
    # Check whether the year leads the filename (e.g. "2023 Movie Name 1080p")
    local before_year
    before_year=$(echo "$norm" | sed "s/[[:space:]]*${year}.*//")
    if [[ -z "$before_year" ]]; then
      # Year-first format: take everything after the year
      title=$(echo "$norm" | sed "s/^[[:space:]]*${year}[[:space:]]*//" )
    else
      # Standard format: everything before the year
      title="$before_year"
    fi
  else
    # No year — strip junk from full name
    title="$norm"
  fi

  title=$(strip_junk "$title")
  title=$(sanitize_for_path "$title")
  title=$(echo "$title" | sed 's/[[:space:]]*-[[:space:]]*$//;s/[[:space:]]*$//')
  MOVIE_TITLE="$title"
}

# ── Core logic ────────────────────────────────────────────────────────────────

# Globals set by parse_tv / parse_movie
SHOW_NAME=""
SEASON_NUM=""
EPISODE_NUM=""
EPISODE_TITLE=""
MOVIE_TITLE=""
MOVIE_YEAR=""

# Process one file. Outputs two lines: target directory, target filename.
# Returns 1 if the file should be skipped (couldn't parse a name).
process_file() {
  local filepath="$1"
  local filename ext stem resolution

  filename=$(basename "$filepath")
  ext="${filename##*.}"
  ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
  stem="${filename%.*}"

  resolution=$(extract_resolution "$stem")

  # Build version-label suffix
  local ver_suffix=""
  [[ -n "$resolution" ]] && ver_suffix=" - ${resolution}"

  # Detect TV show (SxxExx / ##x## pattern in stem)
  if echo "$stem" | grep -qiE '[Ss][0-9]{1,2}[Ee][0-9]{1,2}|[0-9]{1,2}x[0-9]{1,2}'; then
    # TV / anime
    SHOW_NAME="" SEASON_NUM="" EPISODE_NUM="" EPISODE_TITLE=""
    if ! parse_tv "$stem"; then
      echo -e "${YELLOW}[WARN]${NC} Could not parse episode info from: ${filename}" >&2
      return 1
    fi
    if [[ -z "$SHOW_NAME" ]]; then
      echo -e "${YELLOW}[WARN]${NC} Could not determine show name from: ${filename}" >&2
      return 1
    fi
    local season_folder="Season ${SEASON_NUM}"
    local ep_tag="S${SEASON_NUM}E${EPISODE_NUM}"
    local ep_title_part=""
    [[ -n "$EPISODE_TITLE" ]] && ep_title_part=" ${EPISODE_TITLE}"
    local new_filename="${SHOW_NAME} ${ep_tag}${ep_title_part}${ver_suffix}.${ext}"
    local target_dir="${SRC_DIR}/${SHOW_NAME}/${season_folder}"
    echo "$target_dir"
    echo "$new_filename"
  else
    # Movie
    MOVIE_TITLE="" MOVIE_YEAR=""
    parse_movie "$stem"
    if [[ -z "$MOVIE_TITLE" ]]; then
      echo -e "${YELLOW}[WARN]${NC} Could not determine movie title from: ${filename}" >&2
      return 1
    fi
    local folder_name
    if [[ -n "$MOVIE_YEAR" ]]; then
      folder_name="${MOVIE_TITLE} (${MOVIE_YEAR})"
    else
      folder_name="${MOVIE_TITLE}"
    fi
    local new_filename="${folder_name}${ver_suffix}.${ext}"
    local target_dir="${SRC_DIR}/${folder_name}"
    echo "$target_dir"
    echo "$new_filename"
  fi
}

# Move (or dry-run) a file to its target directory and filename.
do_rename() {
  local src_file="$1"
  local target_dir="$2"
  local new_filename="$3"
  local target_path="${target_dir}/${new_filename}"

  # Skip if source and destination are the same
  if [[ "$(realpath "$src_file")" == "$(realpath "$target_path" 2>/dev/null || echo '')" ]]; then
    log_info "Already correct: ${new_filename}"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  if $DRY_RUN; then
    local src_display target_display
    src_display=$(basename "$src_file")
    target_display="${target_dir#${SRC_DIR}/}/${new_filename}"
    echo -e "  ${CYAN}${src_display}${NC}"
    echo -e "  ${BOLD}→${NC} ${GREEN}${target_display}${NC}"
    echo ""
    RENAMED=$((RENAMED + 1))
    return
  fi

  # Conflict check
  if [[ -e "$target_path" ]]; then
    log_warn "Skipping (destination exists): ${target_path}"
    SKIPPED=$((SKIPPED + 1))
    return
  fi

  mkdir -p "$target_dir"
  mv -- "$src_file" "$target_path"
  log_ok "${new_filename}"
  RENAMED=$((RENAMED + 1))
}

# ── Defaults ──────────────────────────────────────────────────────────────────
DRY_RUN=false
RENAMED=0
SKIPPED=0
SRC_DIR=""

# ── Argument parsing ──────────────────────────────────────────────────────────
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run) DRY_RUN=true; shift ;;
    --help)       usage 0 ;;
    -*)           die "Unknown option: $1" ;;
    *)            POSITIONAL+=("$1"); shift ;;
  esac
done

if [[ ${#POSITIONAL[@]} -ge 1 ]]; then
  SRC_DIR="${POSITIONAL[0]}"
else
  SRC_DIR="$PWD"
fi
[[ -d "$SRC_DIR" ]] || die "Directory not found: ${SRC_DIR}"
# Resolve to absolute path, stripping trailing slash
SRC_DIR=$(realpath "$SRC_DIR")

# ── Main ──────────────────────────────────────────────────────────────────────
if $DRY_RUN; then
  log_info "Dry run — no files will be moved."
  echo ""
fi

log_info "Scanning: ${CYAN}${SRC_DIR}${NC}"

mapfile -t FILES < <(find "$SRC_DIR" -maxdepth 1 -type f \
  \( -iname "*.mkv" -o -iname "*.mp4" -o -iname "*.avi" \
     -o -iname "*.mov" -o -iname "*.m4v" -o -iname "*.ts"  \
     -o -iname "*.webm" \) | sort)

if [[ ${#FILES[@]} -eq 0 ]]; then
  log_warn "No video files found in ${SRC_DIR}"
  exit 0
fi

log_info "Found ${#FILES[@]} video file(s)."
$DRY_RUN && echo ""

for filepath in "${FILES[@]}"; do
  # process_file outputs two lines on stdout: target_dir then new_filename.
  # Warnings go to stderr so they are not captured here.
  mapfile -t parsed < <(process_file "$filepath")

  # If process_file emitted a warning line instead of two path lines, skip
  if [[ ${#parsed[@]} -lt 2 ]]; then
    SKIPPED=$((SKIPPED + 1))
    continue
  fi

  target_dir="${parsed[0]}"
  new_filename="${parsed[1]}"

  do_rename "$filepath" "$target_dir" "$new_filename"
done

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
if $DRY_RUN; then
  log_info "Dry run complete — ${CYAN}${RENAMED}${NC} file(s) would be renamed, ${YELLOW}${SKIPPED}${NC} skipped."
else
  log_ok "Done — ${GREEN}${RENAMED}${NC} renamed, ${YELLOW}${SKIPPED}${NC} skipped."
fi
